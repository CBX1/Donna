{
  "name": "donna-slack-bot",
  "version": "1.0.0",
  "description": "Donna - AI-powered Slack assistant for notification triage, PR tracking, tasks, and reminders",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop donna",
    "restart": "pm2 restart donna",
    "logs": "pm2 logs donna --lines 50",
    "dev": "node --watch src/app.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@slack/bolt": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.7",
    "googleapis": "^171.4.0",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.2"
  }
}
